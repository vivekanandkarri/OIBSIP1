# PyVoice Assistant Environment Variables Example
# Copy this file to '.env' and fill in your credentials.

# OpenWeatherMap API Key (For weather information)
# Get one from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Email Credentials (For sending email via SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SENDER_EMAIL=your_email@gmail.com
# For Gmail, use an App Password: https://support.google.com/accounts/answer/185833
SENDER_PASSWORD=your_app_password_here

# Home Assistant REST API
# Obtain a Long-Lived Access Token in your HA Profile page.
HOME_ASSISTANT_URL=http://localhost:8123/api
HOME_ASSISTANT_TOKEN=your_long_lived_access_token_here

# LLM Fallback API Keys (Either OpenAI or Anthropic is supported)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Speech-to-Text Fallback
# If using Whisper API for fallback, it uses the OPENAI_API_KEY from above.
